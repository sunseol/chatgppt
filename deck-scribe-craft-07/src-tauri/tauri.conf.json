{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeckForge",
  "mainBinaryName": "deckforge",
  "version": "0.1.0",
  "identifier": "app.deckforge.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build:package",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DeckForge",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "category": "Productivity",
    "copyright": "Copyright DeckForge"
  }
}
