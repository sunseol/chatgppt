{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeckForge",
  "mainBinaryName": "deckforge",
  "version": "0.0.15",
  "identifier": "app.deckforge.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:8080",
    "frontendDist": "../dist/client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "/",
        "title": "DeckForge",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "backgroundColor": "#f6f1e7"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.png"],
    "macOS": {
      "signingIdentity": "-"
    },
    "category": "Productivity",
    "copyright": "Copyright DeckForge"
  }
}
